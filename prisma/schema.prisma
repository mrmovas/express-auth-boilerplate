generator client {
    provider = "prisma-client"
    output   = "../src/generated/prisma"
}

datasource db {
    provider = "postgresql"
}




// ============================================================
// TABLES
// ============================================================

model User {
  id             String   @id @default(uuid())
  firstName      String
  lastName       String
  passwordHashed String
  email          String   @unique
  emailVerified  Boolean  @default(false)
  phone          Json     // { countryCode: string, number: string }
  role           String   @default("UNASSIGNED")
  lastLoginAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt      // Prisma auto-updates this on every update

  tokens         Token[]  // Relation — lets you do prisma.user.findFirst({ include: { tokens: true } })

  @@map("users")          // Maps to the existing "users" table name in PostgreSQL
}




model Token {
  id           String    @id @default(uuid())
  userID       String
  tokenHashed  String
  tokenType    TokenType
  expiresAt    DateTime
  usedAt       DateTime?
  createdAt    DateTime  @default(now())

  user         User       @relation(fields: [userID], references: [id], onDelete: Cascade)

  @@map("tokens")
}




// ============================================================
// ENUMS
// ============================================================

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}
