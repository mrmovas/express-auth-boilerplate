#SERVER
NODE_ENV=development
LOG_LEVEL=http
PORT=4000

#DATABASE
DATABASE_URL=postgresql://user:password@ipaddress:port/dbname

#SESSION
BETTER_AUTH_SECRET= secret # openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:4000 # Base URL of your app
BETTER_AUTH_LOG_LEVEL=warn # Log level for BetterAuth (error, warn, info, debug)

#SECURITY
RATE_LIMIT_WINDOW_MS=60 # Window size in seconds for rate limiting
RATE_LIMIT_MAX_REQUESTS=100 # Max requests per window per IP

#EMAIL
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_FROM=
EMAIL_PASS=
EMAIL_SECURE= # Use TLS (true for port 465, false for other ports)

#APPLICATION
APP_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

#TOKENS
VERIFICATION_TOKEN_EXPIRE_IN=3600
PASSWORD_RESET_TOKEN_EXPIRE_IN=3600