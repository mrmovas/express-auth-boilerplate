#SERVER
NODE_ENV=development
PORT=3000

#LOGGING
LOG_LEVEL=debug

#DATABASE
DATABASE_URL=postgresql://user:password@ipaddress:port/dbname

#SESSION
SESSION_SECRET=
SESSION_NAME=
SESSION_MAX_AGE=86400000 # 1 day in milliseconds
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000 # Base URL of your app

#SECURITY
RATE_LIMIT_WINDOW_MS=60 # Window size in seconds for rate limiting
RATE_LIMIT_MAX_REQUESTS=100 # Max requests per window per IP

#EMAIL
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_FROM=
EMAIL_PASS=
EMAIL_SECURE= # Use TLS (true for port 465, false for other ports)

#APPLICATION
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

#TOKENS
VERIFICATION_TOKEN_EXPIRE_IN=3600
PASSWORD_RESET_TOKEN_EXPIRE_IN=3600